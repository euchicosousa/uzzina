{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false
	},
	"formatter": {
		"enabled": false
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"recommended": false
			},
			"correctness": {
				"noUnusedVariables": "warn",
				"noUnusedImports": "error"
			}
		}
	},
	"assist": {
		"enabled": false
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
